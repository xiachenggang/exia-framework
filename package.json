{
  "name": "@xiacg/exia-framework",
  "version": "1.0.0",
  "private": true,
  "description": "exia-framework monorepo - Cocos Creator 游戏框架",
  "scripts": {
    "clean": "pnpm -r --parallel clean",
    "build": "pnpm -r  build",
    "build:assets": "pnpm --filter @xiacg/exia-assets build",
    "build:core": "pnpm --filter @xiacg/exia-core build",
    "build:event": "pnpm --filter @xiacg/exia-event build",
    "build:fgui": "pnpm --filter @xiacg/exia-fgui build",
    "build:net": "pnpm --filter @xiacg/exia-net build",
    "build:ccui": "pnpm --filter @xiacg/exia-ccui build",
    "build:all": "pnpm build:core && pnpm build:assets && pnpm build:event && pnpm build:fgui && pnpm build:net && pnpm build:ccui && pnpm copy:dts",
    "copy:dts": "cp exia-core/dist/exia-core.d.ts exia-assets/dist/exia-assets.d.ts exia-event/dist/exia-event.d.ts exia-fgui/dist/exia-fgui.d.ts exia-net/dist/exia-net.d.ts exia-ccui/dist/exia-ccui.d.ts /Users/xiacg/Documents/game/exia-lib/exia-framework-mcp/dts/framework/",
    "publish:core": "pnpm --filter @xiacg/exia-core publish",
    "publish:assets": "pnpm --filter @xiacg/exia-assets publish",
    "publish:event": "pnpm --filter @xiacg/exia-event publish",
    "publish:fgui": "pnpm --filter @xiacg/exia-fgui publish",
    "publish:net": "pnpm --filter @xiacg/exia-net publish",
    "publish:ccui": "pnpm --filter @xiacg/exia-ccui publish",
    "publish:all": "pnpm publish:core && pnpm publish:assets && pnpm publish:event && pnpm publish:fgui && pnpm publish:net && pnpm publish:ccui",
    "version:patch": "pnpm -r exec npm version patch",
    "version:minor": "pnpm -r exec npm version minor",
    "version:major": "pnpm -r exec npm version major"
  },
  "keywords": [
    "exia-framework",
    "cocos",
    "cocos-creator",
    "monorepo",
    "game-framework",
    "fairygui",
    "cocos-creator-ui"
  ],
  "author": "xiacg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiachenggang/exia-framework.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.17.1",
    "pnpm": ">=10.33.0"
  },
  "devDependencies": {
    "@cocos/creator-types": "^3.8.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/lodash": "^4.17.13",
    "@types/node": "^22.10.2",
    "rollup": "^4.28.1",
    "rollup-plugin-dts": "^6.1.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2"
  }
}

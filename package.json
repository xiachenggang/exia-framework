{
  "name": "@xiacg/exia-framework",
  "version": "1.0.0",
  "private": true,
  "description": "exia-framework monorepo - Cocos Creator 游戏框架",
  "scripts": {
    "build:assets": "pnpm --filter @xiacg/exia-assets build",
    "build:core": "pnpm --filter @xiacg/exia-core build",
    "build:event": "pnpm --filter @xiacg/exia-event build",
    "build:all": "pnpm build:core && pnpm build:assets && pnpm build:event && pnpm copy:dts",
    "copy:dts": "cp exia-core/dist/exia-core.d.ts exia-assets/dist/exia-assets.d.ts exia-event/dist/exia-event.d.ts /Users/xiacg/Documents/game/exia-lib/exia-framework-mcp/dts/framework/"
  },
  "keywords": [
    "exia-framework",
    "cocos",
    "cocos-creator",
    "monorepo",
    "game-framework"
  ],
  "author": "xiacg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiachenggang/exia-framework.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "engines": {
    "node": ">=18.17.1",
    "pnpm": ">=10.33.0"
  },
  "devDependencies": {
    "@cocos/creator-types": "^3.8.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/lodash": "^4.17.13",
    "@types/node": "^22.10.2",
    "rollup": "^4.28.1",
    "rollup-plugin-dts": "^6.1.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.6.2"
  }
}

{
  "name": "@xiacg/exia-core",
  "version": "1.0.0",
  "description": "基于creator3.8.8+的exia-core库",
  "main": "./dist/exia-core.cjs",
  "module": "./dist/exia-core.mjs",
  "types": "./dist/exia-core.d.ts",
  "exports": {
    ".": {
      "require": "./dist/exia-core.cjs",
      "import": "./dist/exia-core.mjs",
      "types": "./dist/exia-core.d.ts",
      "default": "./dist/exia-core.cjs"
    },
    "./min": {
      "require": "./dist/exia-core.min.cjs",
      "import": "./dist/exia-core.min.mjs"
    }
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "pnpm run clean && rollup -c rollup.config.mjs"
  },
  "files": [
    "dist"
  ],
  "author": "xiacg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xiachenggang/exia-framework.git",
    "directory": "exia-core"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}

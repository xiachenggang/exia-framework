{
  "name": "@xiacg/exia-net",
  "version": "1.0.6",
  "description": "网络相关库",
  "main": "./dist/exia-net.cjs",
  "module": "./dist/exia-net.mjs",
  "types": "./dist/exia-net.d.ts",
  "exports": {
    ".": {
      "require": "./dist/exia-net.cjs",
      "import": "./dist/exia-net.mjs",
      "types": "./dist/exia-net.d.ts",
      "default": "./dist/exia-net.cjs"
    },
    "./min": {
      "require": "./dist/exia-net.min.cjs",
      "import": "./dist/exia-net.min.mjs"
    }
  },
  "scripts": {
